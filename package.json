{
  "name": "dispatch",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:backend": "turbo dev --filter=@dispatch/backend",
    "dev:cli": "turbo dev --filter=@dispatch/cli",
    "dispatch": "pnpm --filter @dispatch/cli dev",
    "build": "turbo build",
    "test": "turbo test",
    "db:generate": "pnpm --filter @dispatch/backend prisma generate",
    "db:push": "pnpm --filter @dispatch/backend prisma db push",
    "db:studio": "pnpm --filter @dispatch/backend prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "pnpm docker:up && pnpm db:generate && pnpm db:push"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  }
}
