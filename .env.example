# AI
GOOGLE_GENERATIVE_AI_API_KEY=

# Slack (Socket Mode — no public URL needed, no signing secret needed)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Telegram (Polling mode — no public URL needed)
TELEGRAM_BOT_TOKEN=

# Telegram allowlist: comma-separated Telegram user IDs. If empty, all users allowed.
# Get your ID from @userinfobot. Slack is org-level so no allowlist needed.
ALLOWED_TELEGRAM_IDS=

# Persistence
DATABASE_URL=postgres://dispatch:dispatch@localhost:5432/dispatch
REDIS_URL=redis://localhost:6379

# Workflow (use @workflow/world-postgres for production, or omit for local dev)
# WORKFLOW_TARGET_WORLD=@workflow/world-postgres

# Playwright MCP
PLAYWRIGHT_MCP_URL=http://localhost:3001
